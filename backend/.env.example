FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-256-bit-key
JWT_SECRET_KEY=change-this-to-another-random-256-bit-key
# --- Database (PostgreSQL, schema-per-school) ---
# Paste your Neon / Supabase / Railway connection string.
# SQLAlchemy needs the 'postgresql://' scheme (not 'postgres://') — if your
# provider gives you 'postgres://...', just change the prefix.
# One database holds everything: master tables (schools, super_admins) live in
# the public schema; each school gets its own school_<slug> schema.
# MASTER_DATABASE_URL is optional — it defaults to DATABASE_URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
CORS_ORIGINS=http://localhost:4200
